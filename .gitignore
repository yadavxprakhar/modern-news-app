# ==========================================
# Root .gitignore for News Portal Project
# ==========================================

# --- System & OS files ---
.DS_Store
Thumbs.db

# --- IDEs & Editors ---
.vscode/
.idea/
*.iml
*.iws
*.ipr
.classpath
.project
.settings/
.factorypath

# --- Node.js & React (Frontend & Node Backend) ---
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.parcel-cache

# --- Java & Maven (Spring Boot Backend) ---
target/
*.class
*.war
*.ear
*.jar
.mvn/
mvnw
mvnw.cmd
.metadata/

# --- Environment & Credentials ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
